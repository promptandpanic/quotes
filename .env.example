# ──────────────────────────────────────────────────────────────
# Copy this file to .env for local development.
# Never commit .env to git!
# ──────────────────────────────────────────────────────────────

# ── Image provider order ──────────────────────────────────────────────────
# Comma-separated list controlling which image source is tried first.
# Options: leonardo, imagen, gemini, pollinations
# Default (omit this var): leonardo,imagen,gemini,pollinations
# Example — skip Leonardo and use Gemini first:
#   IMAGE_PROVIDER_ORDER=imagen,gemini,pollinations
IMAGE_PROVIDER_ORDER=leonardo,imagen,gemini,pollinations

# ── Leonardo AI (primary image generation — free tier ~150 tokens/day) ───
# Get your key at: https://app.leonardo.ai/ → User Settings → API
LEONARDO_API_KEY=your_leonardo_api_key_here
# Leonardo model ID (default: Leonardo Phoenix, their flagship free model)
# Other options: 1e60896f-3c26-4296-8ecc-53e2afecc132 (Diffusion XL)
LEONARDO_MODEL_ID=6bef9f1b-29cb-40c7-b9df-32b51c1f67d3

# ── Google Gemini (fallback image + all text generation) ──────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Primary text model (used for quotes, design briefs, captions, judging)
GEMINI_TEXT_MODEL=gemini-3.1-pro-preview
# Fallback text model (used if primary is unavailable or rate-limited)
GEMINI_TEXT_MODEL_FALLBACK=gemini-3-flash-preview
# Primary image model (used if Leonardo quota is exhausted)
GEMINI_IMAGE_MODEL=imagen-4.0-fast-generate-001
# Fallback image model (free Gemini tier)
GEMINI_IMAGE_MODEL_FALLBACK=gemini-2.5-flash-image

# ── Instagram Graph API ───────────────────────────────────────
# Long-lived Page / System User access token with permissions:
#   instagram_basic, instagram_content_publish, pages_read_engagement
INSTAGRAM_ACCESS_TOKEN=your_long_lived_instagram_access_token_here

# Your Instagram Business / Creator account numeric ID
# Get it from: https://developers.facebook.com/tools/explorer/
#   → Run: GET /me/accounts  (find your page)  → GET /{page-id}?fields=instagram_business_account
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# ── Email notifications ───────────────────────────────────────
# Sender address — must match the account whose App Password you use
SMTP_USERNAME=yourname@gmail.com
# Display name shown in the recipient's inbox (e.g. "Daily Dose of Wisdom Bot")
SMTP_DISPLAY_NAME=Daily Dose of Wisdom Bot
# Gmail App Password (NOT your login password)
# Generate at: Google Account → Security → 2-Step Verification → App passwords
# Choose "Mail" + "Other (custom)" → name it "quotes-bot" → copy the 16-char code
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# Comma-separated list of recipient emails
NOTIFY_EMAILS=you@gmail.com,partner@gmail.com

# ── GitHub (auto-set in Actions; needed locally only) ─────────
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPOSITORY=your_username/your_repo_name
