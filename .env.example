# ──────────────────────────────────────────────────────────────
# Copy this file to .env for local development.
# Never commit .env to git!
# ──────────────────────────────────────────────────────────────

# ── Image provider order ──────────────────────────────────────
# Comma-separated list — tried left to right, first success wins.
# Options: huggingface, leonardo, imagen, gemini, pollinations
# Change here (or in GitHub Variables) when a provider runs out of credits.
IMAGE_PROVIDER_ORDER=huggingface,leonardo,imagen,gemini,pollinations

# ── HuggingFace (primary image generation — free tier, FLUX.1-schnell) ───
# Get your key at: https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_key_here
# HuggingFace model ID — swap here to try other models without touching code
# Options: black-forest-labs/FLUX.1-schnell (free) | black-forest-labs/FLUX.1-dev (PRO)
HF_MODEL_ID=black-forest-labs/FLUX.1-schnell

# ── Leonardo AI (paid / free tier ~150 tokens/day) ───────────────────────
# Get your key at: https://app.leonardo.ai/ → User Settings → API
LEONARDO_API_KEY=your_leonardo_api_key_here
# Leonardo model ID
# Options: flux-pro-2.0  |  6bef9f1b-29cb-40c7-b9df-32b51c1f67d3 (Phoenix)
LEONARDO_MODEL_ID=flux-pro-2.0

# ── Google Gemini (fallback image + all text generation) ──────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Primary text model (quotes, design briefs, captions, judging)
GEMINI_TEXT_MODEL=gemini-2.5-flash
# Fallback text model (used if primary is rate-limited or unavailable)
GEMINI_TEXT_MODEL_FALLBACK=gemini-3-flash-preview
# Primary image model (used if Leonardo quota is exhausted)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Fallback image model
GEMINI_IMAGE_MODEL_FALLBACK=imagen-4.0-fast-generate-001

# ── Instagram Graph API ───────────────────────────────────────
# Long-lived Page / System User access token with permissions:
#   instagram_basic, instagram_content_publish, pages_read_engagement
INSTAGRAM_ACCESS_TOKEN=your_long_lived_instagram_access_token_here

# Your Instagram Business / Creator account numeric ID
# Get it from: https://developers.facebook.com/tools/explorer/
#   → Run: GET /me/accounts  (find your page)
#   → Run: GET /{page-id}?fields=instagram_business_account
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# ── Email notifications ───────────────────────────────────────
# Sender address — must match the account whose App Password you use
SMTP_USERNAME=yourname@gmail.com
# Display name shown in recipient's inbox
SMTP_DISPLAY_NAME="Daily Dose of Wisdom Bot"
# Gmail App Password (NOT your login password)
# Generate at: Google Account → Security → 2-Step Verification → App passwords
# Choose "Mail" + "Other (custom)" → name it "quotes-bot" → copy the 16-char code
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# Comma-separated list of recipient emails
NOTIFY_EMAILS=you@gmail.com,partner@gmail.com

# ── GitHub (auto-set in Actions; needed locally only) ─────────
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPOSITORY=your_username/your_repo_name

# ── TTS Narration ─────────────────────────────────────────────
# Provider cascade — tried left to right, first success wins.
# "none" = intentionally silent (safe catchall, always last).
TTS_PROVIDERS=elevenlabs,edge,none

# ElevenLabs — premium neural voices
# Comma-separated list of API keys — rotates automatically on quota/limit hit.
# Get keys at: https://elevenlabs.io → Profile → API Key
# Free tier: 10,000 chars/month, premade voices only.
# Starter ($5/mo): 30,000 chars/month + Voice Library access.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here,your_second_key_here_optional
# Model: eleven_multilingual_v2 (best quality) | eleven_turbo_v2_5 (faster/cheaper)
ELEVENLABS_MODEL=eleven_multilingual_v2

# Global voice overrides — only set these to swap the default voices.
# All per-theme defaults (ELEVENLABS_VOICE_MORNING_MALE etc.) live in src/config.py.
# Browse & preview voices at: https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_MALE=kqVT88a5QfII1HNAEPTJ    # Declan Sage  — Wise, Captivating (global male fallback)
# ELEVENLABS_VOICE_FEMALE=KoVIHoyLDrQyd4pGalbs  # Autumn Veil  — Deep, Thoughtful (global female fallback)

# edge-tts — free Microsoft neural voices (disabled by default, no API key needed)
# Set EDGE_TTS_ENABLED=true (in secrets/env) to use as fallback when ElevenLabs quota is exhausted.
# When disabled, a failed ElevenLabs call falls through to music-only (no narration).
# Run `edge-tts --list-voices` to see all available voices.
EDGE_TTS_ENABLED=false
EDGE_TTS_VOICE_MALE=en-IN-PrabhatNeural
EDGE_TTS_VOICE_FEMALE=en-IN-NeerjaExpressiveNeural

# Static voice gender used when no AI brief is available
# (curated/fallback quotes that skip the design director)
TTS_STATIC_VOICE_GENDER=male

# Background music volume (0.0–1.0) when TTS narration is active.
# 0.12 ≈ -18 dB — ducks the music comfortably under the spoken voice.
TTS_MUSIC_VOLUME=0.12
